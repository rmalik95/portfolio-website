# ============================================
# SECURITY-CRITICAL FILES - NEVER COMMIT!
# ============================================

# Environment variables (contains secrets, API keys, passwords)
.env
.env.local
.env.production
.env.development
.env.*.local
**/.env
**/.env.*

# SSL/TLS Certificates and Keys
*.pem
*.key
*.crt
*.cer
*.p12
*.pfx
*.jks
*.keystore

# SSH Keys
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
*.ppk

# Database dumps and backups
*.sql
*.sqlite
*.sqlite3
*.db
*.dump
backup/
backups/

# Logs (may contain sensitive information)
*.log
logs/
*.log.*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

